+# Django Security Settings
+# Copy this file to .env and fill in your values
+
+# SECURITY WARNING: Keep this secret!
+# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
+SECRET_KEY=your-super-secret-key-min-50-characters-long-random-string-here
+
+# Set to False in production
+DEBUG=False
+
+# Comma-separated list of allowed hosts
+ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com
+
+# Database settings (PostgreSQL recommended for production)
+DB_ENGINE=django.db.backends.postgresql
+DB_NAME=your_database_name
+DB_USER=your_database_user
+DB_PASSWORD=your_secure_database_password
+DB_HOST=localhost
+DB_PORT=5432
+
+# Email settings (for password reset, etc.)
+EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
+EMAIL_HOST=smtp.gmail.com
+EMAIL_PORT=587
+EMAIL_USE_TLS=True
+EMAIL_HOST_USER=your_email@gmail.com
+EMAIL_HOST_PASSWORD=your_app_password
+
+# Security flags
+CSRF_COOKIE_SECURE=True
+SESSION_COOKIE_SECURE=True
+SECURE_SSL_REDIRECT=True
+
+# CORS settings (if using API)
+CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
